# ===============================================
# VOICE TUTOR SERVICE CONFIGURATION (Render Web)
# ===============================================

# Port to bind the WebSocket server (Render automatically injects this)
PORT=10000

# Gemini API Key (Required for raw WebRTC audio streams)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_API_KEY_1="backup-rotated-key-optional"

# Upstash Redis Connection (Required for loading/saving chat memories)
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# Backend Retrieval Settings
FRAPPE_URL="https://your-frappe-backend-url.com" # Points to the Frappe API endpoint
INTERNAL_SERVICE_TOKEN="internal_key_123" # Token used to call retrieve_secure_chunks_internal

