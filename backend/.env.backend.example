# ===============================================
# FRAPPE LMS BACKEND CONFIGURATION (Render Docker)
# ===============================================

# Port Render binds the HTTP routing to (automatically set by Render)
PORT=8000

# The base URL of your deployed frontend (Vercel URL, used for CORS configuration)
FRONTEND_URL="https://vyomanta.vercel.app"

# Remote MySQL/MariaDB database details for Frappe persistence
DB_HOST="gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com"
DB_PORT="4000"
DB_USER="your-database-user-string"
DB_PASSWORD="your-database-password"
DB_NAME="your-frappe-db-name"

# Administrator user password for the Frappe Admin Workspace dashboard
ADMIN_PASSWORD="admin"

# Upstash Redis Connection (Used for permission cache invalidations & ingestion Pub/Sub status relaying)
UPSTASH_REDIS_REST_URL="https://your-database-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# API Keys (For rotated queue worker text embeddings)
GEMINI_API_KEY="your-main-gemini-key"
GEMINI_API_KEY_1="rotated-key-1-optional"
GEMINI_API_KEY_2="rotated-key-2-optional"

# Security & JWT Tokens
INTERNAL_SERVICE_TOKEN="internal_key_123" # Shared secret to protect internal retrieve_secure_chunks_internal endpoint

# Backblaze B2 Storage Configuration
B2_KEY_ID="your-b2-key-id"
B2_APPLICATION_KEY="your-b2-application-key"
B2_BUCKET_NAME="your-b2-bucket-name"
B2_ENDPOINT="https://s3.us-west-004.backblazeb2.com"
B2_REGION="us-west-004"

